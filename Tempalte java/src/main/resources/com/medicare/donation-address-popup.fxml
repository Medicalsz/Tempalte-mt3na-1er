<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox fx:id="rootPane" alignment="CENTER" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 10); -fx-border-color: #10b981; -fx-border-radius: 15; -fx-border-width: 2;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.medicare.controllers.DonationAddressPopupController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    <children>
        <FontIcon iconLiteral="fas-heart" iconSize="48" iconColor="#10b981" />
        
        <Label text="Merci pour votre générosité !" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
        
        <VBox alignment="CENTER" spacing="10.0">
            <children>
                <Label fx:id="thankYouLabel" text="Votre don a été confirmé par un administrateur." wrapText="true" textAlignment="CENTER" style="-fx-font-size: 14px; -fx-text-fill: #64748b;" />
                <Label fx:id="objectsLabel" text="(Objets donnés)" wrapText="true" textAlignment="CENTER" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #10b981;" />
            </children>
        </VBox>
        
        <Label text="Veuillez nous indiquer l'adresse où nos équipes pourront récupérer votre don :" wrapText="true" textAlignment="CENTER" style="-fx-font-size: 14px; -fx-text-fill: #1e293b;" />
        
        <VBox spacing="5.0">
            <children>
                <TextField fx:id="addressField" promptText="Saisissez votre adresse complète..." style="-fx-padding: 12; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;" />
                <Label fx:id="errorLabel" text="L'adresse est requise (min. 10 caractères)" visible="false" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;" />
            </children>
        </VBox>
        
        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Button fx:id="confirmButton" onAction="#onConfirm" text="Confirmer l'adresse" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 30; -fx-background-radius: 30; -fx-cursor: hand;" />
            </children>
        </HBox>
    </children>
</VBox>
