<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.medicare.controllers.AdminCollaborationsController"
           style="-fx-background-color: #f3f4f6; -fx-padding: 20;">
    <children>
        <VBox fx:id="container" spacing="10" alignment="TOP_CENTER"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
            <!-- Le contenu sera ajouté dynamiquement par le contrôleur -->
        </VBox>
    </children>
</StackPane>