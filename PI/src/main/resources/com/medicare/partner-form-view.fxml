<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.medicare.controllers.PartnerFormController"
      spacing="15" style="-fx-background-color: white; -fx-padding: 30;">

    <Label text="Ajouter/Modifier Partenaire" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;"/>
    <Separator/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints hgrow="NEVER" minWidth="100"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Nom:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nomField" promptText="Nom du partenaire" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Type:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="typeField" promptText="Ex: Hôpital, Clinique" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Email:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="emailField" promptText="Email de contact" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Téléphone:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="phoneField" promptText="Téléphone de contact" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Adresse:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="adresseField" promptText="Adresse du partenaire" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Statut:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="statutField" promptText="Actif / Inactif" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Date Partenariat:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <DatePicker fx:id="datePicker" promptText="Date de début" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#handleCancel" style="-fx-background-color: #e5e7eb; -fx-text-fill: #333;"/>
        <Button fx:id="saveBtn" text="Enregistrer" onAction="#handleSave" style="-fx-background-color: #7c3aed; -fx-text-fill: white;"/>
    </HBox>

</VBox>