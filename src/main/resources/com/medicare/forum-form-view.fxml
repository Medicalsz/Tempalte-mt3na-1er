<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.medicare.controllers.ForumFormController">
    <content>
        <VBox spacing="18" maxWidth="760" style="-fx-background-color: transparent;">
            <padding>
                <Insets top="16" right="18" bottom="24" left="18"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Button text="Retour" onAction="#onBackClick"
                        style="-fx-background-color: #fff7ed; -fx-text-fill: #c2410c; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 9 16;"/>
                <Label fx:id="formTitleLabel" text="Nouveau sujet"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f97316;"/>
            </HBox>

            <VBox spacing="16"
                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 14, 0, 0, 3);">
                <padding>
                    <Insets top="20" right="22" bottom="22" left="22"/>
                </padding>

                <VBox spacing="6">
                    <Label text="Titre du sujet"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
                    <TextField fx:id="titleField" prefHeight="40"
                               promptText="Ex: Comment mieux gerer le stress au quotidien ?"
                               style="-fx-background-radius: 10; -fx-font-size: 13px;"/>
                </VBox>

                <HBox spacing="14">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Type"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
                        <ComboBox fx:id="typeCombo" prefHeight="40"
                                  style="-fx-background-radius: 10; -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Tags"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
                        <TextField fx:id="tagsField" prefHeight="40"
                                   promptText="stress, sante, sommeil"
                                   style="-fx-background-radius: 10; -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>

                <VBox fx:id="videoUrlBox" spacing="6">
                    <Label text="URL video"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
                    <TextField fx:id="videoUrlField" prefHeight="40"
                               promptText="https://..."
                               style="-fx-background-radius: 10; -fx-font-size: 13px;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Resume"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
                    <TextArea fx:id="summaryArea" prefRowCount="3" wrapText="true"
                              promptText="Resume court affiche dans la liste..."
                              style="-fx-background-radius: 10; -fx-font-size: 13px;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Contenu"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
                    <TextArea fx:id="contentInputArea" prefRowCount="12" wrapText="true"
                              promptText="Detaillez votre sujet ici..."
                              style="-fx-background-radius: 10; -fx-font-size: 13px;"/>
                </VBox>

                <Label fx:id="errorLabel" text=""
                       style="-fx-text-fill: #dc2626; -fx-font-size: 13px;"/>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Annuler" onAction="#onBackClick"
                            style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 10 18;"/>
                    <Button fx:id="saveButton" text="Publier le sujet" onAction="#onSaveClick"
                            style="-fx-background-color: #f97316; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 10 18;"/>
                </HBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
