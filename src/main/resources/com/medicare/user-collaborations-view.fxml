<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<VBox styleClass="collaborations-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.medicare.controllers.CollaborationController">
    <Label text="Mes Collaborations" styleClass="title"/>
    <ScrollPane fx:id="scrollPane" fitToWidth="true" styleClass="scroll-pane">
        <TilePane fx:id="collaborationsPane" hgap="20" vgap="20" styleClass="tile-pane"/>
    </ScrollPane>
</VBox>