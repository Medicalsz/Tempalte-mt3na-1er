<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Separator?>

<BorderPane prefWidth="950" prefHeight="620"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.medicare.controllers.DashboardMedecinController"
            stylesheets="@dashboard-sidebar.css">

    <left>
        <VBox prefWidth="220" spacing="5"
              style="-fx-background-color: #0d9488;">
            <padding>
                <Insets top="20" bottom="20" left="10" right="10"/>
            </padding>

            <Label text="Medicare" prefWidth="200" alignment="CENTER" styleClass="sidebar-logo"/>

            <VBox fx:id="profileCard" alignment="CENTER" spacing="8" prefWidth="200" styleClass="sidebar-profile-card">
                <Label fx:id="avatarInitialsLabel" text="DR" styleClass="sidebar-avatar"/>
                <Label fx:id="userNameLabel" text="Medecin" wrapText="true" alignment="CENTER" styleClass="sidebar-profile-name"/>
                <Label fx:id="userEmailLabel" text="Doctor" alignment="CENTER" styleClass="sidebar-profile-role"/>
                <HBox alignment="CENTER" spacing="6">
                    <Region styleClass="sidebar-status-dot"/>
                    <Label text="En ligne" styleClass="sidebar-status-text"/>
                </HBox>
                <Label fx:id="roleBadgeLabel" text="Doctor" styleClass="sidebar-role-badge sidebar-role-doctor"/>
            </VBox>

            <Separator/>

            <Button fx:id="btnRendezVous" text="  Rendez-vous" onAction="#onRendezVousClick"
                    prefWidth="200" prefHeight="38" alignment="CENTER_LEFT"
                    style="-fx-background-color: #14b8a6; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;"/>

            <Button fx:id="btnPlanning" text="  Planning" onAction="#onPlanningClick"
                    prefWidth="200" prefHeight="38" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;"/>

            <Button fx:id="btnForum" text="  Forum" onAction="#onForumClick"
                    prefWidth="200" prefHeight="38" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;"/>

            <Button fx:id="btnNotifications" text="  Notifications" onAction="#onNotificationsClick"
                    prefWidth="200" prefHeight="38" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator/>

            <Button fx:id="btnLogout" text="  Deconnexion" onAction="#onLogoutClick"
                    prefWidth="200" prefHeight="38" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: #fecaca; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-background-color: #f0f4f8;">
            <padding>
                <Insets top="20" bottom="20" left="20" right="20"/>
            </padding>
            <Label text="Bienvenue sur votre espace medecin !"
                   style="-fx-font-size: 22px; -fx-text-fill: #333; -fx-font-weight: bold;"/>
        </StackPane>
    </center>
</BorderPane>
