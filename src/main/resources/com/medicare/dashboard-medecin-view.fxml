<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="950" prefHeight="620"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.medicare.controllers.DashboardMedecinController">

    <left>
        <VBox prefWidth="220" spacing="8"
              style="-fx-background-color: #0d9488;">
            <padding>
                <Insets top="20" bottom="20" left="10" right="10"/>
            </padding>

            <Button fx:id="userProfileButton" onAction="#onProfileClick"
                    prefWidth="200" alignment="CENTER_LEFT"
                    style="-fx-background-color: rgba(255,255,255,0.12); -fx-background-radius: 16; -fx-cursor: hand; -fx-padding: 12;">
                <graphic>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <ImageView fx:id="userAvatarView" fitWidth="56" fitHeight="56" pickOnBounds="true" preserveRatio="false"/>
                        <VBox spacing="2" alignment="CENTER_LEFT">
                            <Label fx:id="userNameLabel" text="Medecin"
                                   style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                            <Label fx:id="userRoleLabel" text="Medecin"
                                   style="-fx-text-fill: #ccfbf1; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                            <Label fx:id="userEmailLabel" text=""
                                   style="-fx-text-fill: #99f6e4; -fx-font-size: 10px;"/>
                        </VBox>
                    </HBox>
                </graphic>
            </Button>

            <Separator/>

            <Button fx:id="btnRendezVous" text="  Rendez-vous" onAction="#onRendezVousClick"
                    prefWidth="200" prefHeight="38" alignment="CENTER_LEFT"
                    style="-fx-background-color: #14b8a6; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;"/>

            <Button fx:id="btnPlanning" text="  Planning" onAction="#onPlanningClick"
                    prefWidth="200" prefHeight="38" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;"/>

            <Button fx:id="btnSettings" text="  Parametres" onAction="#onSettingsClick"
                    prefWidth="200" prefHeight="38" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator/>

            <Button fx:id="btnLogout" text="  Deconnexion" onAction="#onLogoutClick"
                    prefWidth="200" prefHeight="38" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: #fecaca; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-background-color: #f0f4f8;">
            <padding>
                <Insets top="20" bottom="20" left="20" right="20"/>
            </padding>
            <Label text="Bienvenue sur votre espace medecin !"
                   style="-fx-font-size: 22px; -fx-text-fill: #333; -fx-font-weight: bold;"/>
        </StackPane>
    </center>
</BorderPane>
