<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" spacing="15" prefWidth="500" prefHeight="550"
      style="-fx-background-color: #f0f4f8;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.medicare.controllers.RegisterController">
    <padding>
        <Insets bottom="30" left="50" right="50" top="30"/>
    </padding>

    <Label text="Creer un compte"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1a73e8;"/>

    <TextField fx:id="nomField" promptText="Nom" prefHeight="36"
               style="-fx-background-radius: 8; -fx-font-size: 14px;"/>

    <TextField fx:id="prenomField" promptText="Prenom" prefHeight="36"
               style="-fx-background-radius: 8; -fx-font-size: 14px;"/>

    <TextField fx:id="emailField" promptText="Email" prefHeight="36"
               style="-fx-background-radius: 8; -fx-font-size: 14px;"/>

    <PasswordField fx:id="passwordField" promptText="Mot de passe" prefHeight="36"
                   style="-fx-background-radius: 8; -fx-font-size: 14px;"/>

    <PasswordField fx:id="confirmPasswordField" promptText="Confirmer le mot de passe" prefHeight="36"
                   style="-fx-background-radius: 8; -fx-font-size: 14px;"/>

    <TextField fx:id="numeroField" promptText="Numero de telephone" prefHeight="36"
               style="-fx-background-radius: 8; -fx-font-size: 14px;"/>

    <TextField fx:id="adresseField" promptText="Adresse (optionnel)" prefHeight="36"
               style="-fx-background-radius: 8; -fx-font-size: 14px;"/>

    <Label fx:id="errorLabel" text=""
           style="-fx-text-fill: #dc2626; -fx-font-size: 13px;"/>

    <Button text="S'inscrire" onAction="#onRegisterClick" prefWidth="250" prefHeight="40"
            style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-size: 15px; -fx-background-radius: 8; -fx-cursor: hand;"/>

    <HBox alignment="CENTER" spacing="5">
        <Label text="Deja un compte ?"
               style="-fx-font-size: 13px; -fx-text-fill: #666;"/>
        <Hyperlink text="Se connecter" onAction="#onGoToLogin"
                   style="-fx-font-size: 13px; -fx-text-fill: #1a73e8;"/>
    </HBox>

    <Hyperlink text="Retour a l'accueil" onAction="#onGoToAccueil"
               style="-fx-font-size: 12px; -fx-text-fill: #999;"/>
</VBox>

