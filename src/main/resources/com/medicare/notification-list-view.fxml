<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<ScrollPane fitToWidth="true"
            hbarPolicy="NEVER"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.medicare.controllers.NotificationController"
            styleClass="notification-scroll">
    <stylesheets>
        <URL value="@notification.css"/>
    </stylesheets>
    <content>
        <VBox spacing="18" styleClass="notification-page">
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="14" styleClass="notification-header">
                <VBox spacing="5">
                    <Label text="Notifications" styleClass="notification-page-title"/>
                    <Label fx:id="notificationStatsLabel"
                           text="Chargement..."
                           styleClass="notification-page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="markAllButton"
                        text="Tout marquer comme lu"
                        onAction="#onMarkAllAsReadClick"
                        styleClass="notification-mark-all-button"/>
            </HBox>

            <Label fx:id="emptyLabel"
                   text="Aucune notification pour le moment."
                   styleClass="notification-empty"/>

            <VBox fx:id="notificationsContainer" spacing="12"/>
        </VBox>
    </content>
</ScrollPane>
