<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.medicare.controllers.ForumModerationController">
    <content>
        <VBox spacing="18" style="-fx-background-color: transparent;">
            <padding>
                <Insets top="16" right="18" bottom="24" left="18"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Button text="Retour au forum" onAction="#onBackClick"
                        style="-fx-background-color: #fff7ed; -fx-text-fill: #c2410c; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 9 16;"/>
                <VBox spacing="4">
                    <Label text="Moderation du forum"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #b45309;"/>
                    <Label fx:id="headerStatsLabel" text="Synchronise avec la base Symfony"
                           style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Actualiser" onAction="#onRefreshClick"
                        style="-fx-background-color: #fef3c7; -fx-text-fill: #b45309; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 9 16;"/>
            </HBox>

            <Label fx:id="errorLabel" text=""
                   style="-fx-text-fill: #dc2626; -fx-font-size: 13px;"/>

            <VBox spacing="14"
                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 14, 0, 0, 3);">
                <padding>
                    <Insets top="20" right="22" bottom="22" left="22"/>
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox spacing="4">
                        <Label text="Sujets moderes"
                               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        <Label fx:id="topicStatsLabel" text="0 sujet"
                               style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="topicFilterCombo" prefWidth="230" prefHeight="40"
                              style="-fx-background-radius: 10; -fx-font-size: 13px;"/>
                </HBox>

                <Label fx:id="emptyTopicsLabel" text="Aucun sujet modere pour ce filtre."
                       managed="false" visible="false"
                       style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>

                <VBox fx:id="moderatedTopicsContainer" spacing="12"/>
            </VBox>

            <VBox spacing="14"
                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 14, 0, 0, 3);">
                <padding>
                    <Insets top="20" right="22" bottom="22" left="22"/>
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox spacing="4">
                        <Label text="Commentaires moderes"
                               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        <Label fx:id="commentStatsLabel" text="0 commentaire"
                               style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="commentFilterCombo" prefWidth="270" prefHeight="40"
                              style="-fx-background-radius: 10; -fx-font-size: 13px;"/>
                </HBox>

                <Label fx:id="emptyCommentsLabel" text="Aucun commentaire modere pour ce filtre."
                       managed="false" visible="false"
                       style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>

                <VBox fx:id="moderatedCommentsContainer" spacing="12"/>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
