<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<!-- The root is a ScrollPane to allow content to scroll. -->
<!-- The stylesheet is linked directly here to ensure it's loaded. -->
<ScrollPane styleClass="partner-detail-scroll-pane" fitToWidth="true"
            stylesheets="@partner-detail-style.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.medicare.controllers.PartnerDetailController">

    <VBox fx:id="mainVBox" styleClass="partner-detail-container" spacing="20">

        <!-- Card 1: Partner Info -->
        <Pane styleClass="info-card">
            <VBox spacing="15">
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <ImageView fx:id="partnerImageView" fitHeight="80" fitWidth="80" styleClass="partner-image"/>
                    <VBox>
                        <Label fx:id="partnerNameLabel" styleClass="partner-name"/>
                        <Label fx:id="partnerTypeLabel" styleClass="partner-type"/>
                    </VBox>
                </HBox>
                <GridPane fx:id="detailsGrid" styleClass="details-grid" hgap="10" vgap="10">
                    <!-- Content is added dynamically by the controller -->
                </GridPane>
            </VBox>
        </Pane>

        <!-- Card 2: Reputation -->
        <Pane styleClass="reputation-card">
            <VBox spacing="10">
                <Label text="Réputation" styleClass="card-title"/>
                <HBox fx:id="ratingBox" alignment="CENTER_LEFT" spacing="5">
                    <!-- Stars and rating label are added here by the controller -->
                </HBox>
                <HBox fx:id="badgesBox" alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="reputation-label" text="Badges :"/>
                    <!-- Badges are added here by the controller -->
                </HBox>
            </VBox>
        </Pane>

        <!-- Section 3: Comments -->
        <VBox spacing="10">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Commentaires" styleClass="card-title"/>
                <Label fx:id="commentsToggleLabel" styleClass="toggle-label" onMouseClicked="#toggleCommentsVisibility"/>
            </HBox>
            <VBox fx:id="commentsVBox" styleClass="comments-container" spacing="10" managed="false" visible="false"/>
        </VBox>

        <!-- Card 4: Add Comment Form -->
        <Pane styleClass="add-comment-card">
            <VBox spacing="10">
                <Label text="Laissez un avis" styleClass="card-title"/>
                <TextArea fx:id="commentTextArea" promptText="Écrivez votre commentaire ici..." wrapText="true"/>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Note :" styleClass="reputation-label"/>
                    <HBox fx:id="addRatingBox" spacing="2"/>
                </HBox>
                <Button fx:id="submitCommentButton" text="Soumettre" onAction="#handleSubmitComment"/>
            </VBox>
        </Pane>

    </VBox>
</ScrollPane>