<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.medicare.controllers.StripeCheckoutController"
      style="-fx-background-color: white;">

    <HBox spacing="12" alignment="CENTER_LEFT"
          style="-fx-background-color: #1a73e8; -fx-padding: 14 18;">
        <Label text="Paiement securise" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Label fx:id="amountLabel" text="" style="-fx-font-size: 13px; -fx-text-fill: #c7dbff;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Stripe Test Mode" style="-fx-font-size: 11px; -fx-text-fill: #c7dbff; -fx-padding: 3 8; -fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 4;"/>
    </HBox>

    <StackPane VBox.vgrow="ALWAYS">
        <WebView fx:id="webView" prefWidth="780" prefHeight="640"/>
        <VBox fx:id="loaderPane" alignment="CENTER" spacing="10"
              style="-fx-background-color: rgba(255,255,255,0.95);">
            <ProgressIndicator/>
            <Label text="Connexion a Stripe..." style="-fx-text-fill: #555; -fx-font-size: 13px;"/>
        </VBox>
    </StackPane>

    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 18; -fx-background-color: #f9fafb;">
        <Label fx:id="hintLbl" text="Carte test : 4242 4242 4242 4242 — date future, CVC libre"
               style="-fx-font-size: 11px; -fx-text-fill: #6b7280;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Annuler" onAction="#onCancel"
                style="-fx-background-color: #e5e7eb; -fx-text-fill: #333; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 16;"/>
    </HBox>
</VBox>
